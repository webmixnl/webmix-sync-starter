SITE_KEY="example-site"
SSH_HOST="example.host"
SSH_PORT="22"
SSH_USER="cpaneluser"
ENVIRONMENT="staging"

# Local root should normally point to wp-content, not the full site.
LOCAL_ROOT="$HOME/Sites/example-site/public_html/wp-content"

# Remote root should normally point to wp-content as well.
REMOTE_ROOT="/home/cpaneluser/public_html/wp-content"

# One relative path per line. Only these folders are synced.
SYNC_ITEMS="themes/client-theme
plugins/client-plugin"

# 0 = safer default, 1 = allow rsync --delete
RSYNC_DELETE="0"

# Used by watch mode.
DEBOUNCE_SECONDS="1"

# Optional custom SSH identity file.
# SSH_KEY_FILE="$HOME/.ssh/id_rsa_bram"
