#!/usr/bin/env bash
# Don't use -e or -o pipefail - we want to handle errors gracefully and keep watching
# Only use -u for undefined variable checking
set -u

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck disable=SC1091
source "$SCRIPT_DIR/../lib/common.sh"

# Override set -e and pipefail from common.sh - we want to handle errors gracefully
set +e
set +o pipefail

SITE_KEY="${1:-}"
[[ -n "$SITE_KEY" ]] || usage_site_arg
shift || true

DRY_RUN=0
if [[ "${1:-}" == "--dry-run" ]]; then
  DRY_RUN=1
fi

require_command rsync
require_command ssh
require_command fswatch
load_site_config "$SITE_KEY"
assert_watch_paths_exist
print_summary

log "Watching for local changes..."
log "Debounce seconds: $DEBOUNCE_SECONDS"

last_run=0
pending=0

trigger_sync() {
  local now
  now="$(date +%s)"
  if (( now - last_run < DEBOUNCE_SECONDS )); then
    pending=1
    return
  fi

  last_run="$now"
  pending=0
  
  # Run push and capture exit code - don't exit on failure
  if run_all_push; then
    log "Sync complete"
  else
    log "Push failed; waiting for next change."
  fi
}

# Start fswatch and process events
watch_paths | xargs fswatch -0 2>&1 | while IFS= read -r -d '' event; do
  trigger_sync

  if (( pending == 1 )); then
    sleep "$DEBOUNCE_SECONDS"
    trigger_sync
  fi
done

# If we exit the loop, fswatch stopped
fswatch_exit=$?
exit_code=$?
if [[ $exit_code -ne 0 ]]; then
  log "fswatch exited with code $exit_code"
else
  log "fswatch stopped unexpectedly"
fi
exit $exit_code
